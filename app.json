{
  "name": "Vanguard MD",
  "description": "Advanced WhatsApp Bot made by Admin Blue",
  "logo": "https://files.catbox.moe/bjb9zv.jpg",
  "keywords": ["vanguard", "whatsapp-bot", "baileys", "md"],
  "success_url": "/",
  "stack": "container",
  "env": {
    "SESSION_ID": {
      "description": "VANGUARD-MD;;; session ID for authentication (Required)",
      "required": true,
      "value": ""
    },
    "PHONE_NUMBER": {
      "description": "Fallback phone number with country code (e.g., 254110442027). Only used if no session ID is set.",
      "required": false,
      "value": ""
    },
    "PREFIX": {
      "description": "Bot command prefix",
      "required": false,
      "value": "."
    },
    "MODE": {
      "description": "Bot mode: public,private,inbox or groups",
      "required": false,
      "value": "public"
    }
  }
}
